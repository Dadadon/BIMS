APP_NAME=BIMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bims
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@bims.app"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=bims-app
REVERB_APP_KEY=bims-key
REVERB_APP_SECRET=bims-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

WKHTMLTOPDF_PATH=/usr/local/bin/wkhtmltopdf
WKHTMLTOIMAGE_PATH=/usr/local/bin/wkhtmltoimage

MAX_CHAT_ATTACHMENT_MB=10

# ── External Authentication ──────────────────────────────────────────────────
# Microsoft Entra ID / Azure AD (OIDC)
# Register an app at https://portal.azure.com → App registrations
# Add redirect URI: https://yourdomain.com/auth/oidc/callback
# Set external_auth_domains in Settings to map email domains to "oidc"
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_TENANT_ID=common
OIDC_REDIRECT_URI=

# Samba / Active Directory (LDAP)
# Enable by setting LDAP_HOST and configuring external_auth_domains to map domains to "ldap"
# Requires the PHP ldap extension to be enabled on the server
LDAP_HOST=
LDAP_PORT=389
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(mail=%s)
# JSON mapping of AD group CN names to BIMS role slugs
# Example: {"Domain Admins":"system_admin","Managers":"manager"}
LDAP_ROLE_MAPPING={}
